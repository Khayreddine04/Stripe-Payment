# Replace with your actual domain
VIRTUAL_HOST=your-actual-domain.com
LETSENCRYPT_EMAIL=your-email@example.com

# Database configuration
DB_HOST=db
DB_DATABASE=stripe_payment
DB_USERNAME=user
DB_PASSWORD=password

# Stripe configuration
STRIPE_KEY=your_stripe_key_here
STRIPE_SECRET=your_stripe_secret_here
STRIPE_WEBHOOK_SECRET=your_webhook_secret_here

# Application URL (must match your domain)
APP_URL=https://${VIRTUAL_HOST}
APP_ENV=production
APP_DEBUG=false

# Session configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail configuration
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@${VIRTUAL_HOST}"
MAIL_FROM_NAME="${APP_NAME}"
